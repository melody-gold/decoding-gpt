    "some_text += \"The quick red fox jumps over the lazy brown dog. The quick red fox jumps over the lazy brown dog.\"\n",
    "\n",
    "def clean_text(text: str) -> list[str]:\n",
    "\t\"clean the text to only lowercase letters and spaces\"\n",
    "\treturn [x for x in text.lower() if x.isalpha() or x == ' ']\n",
    "\n",
    "some_text_chars: list[str] = clean_text(some_text)\n",
    "char_vocab: list[str] = sorted(set(some_text_chars))\n",
    "print(char_vocab)"
