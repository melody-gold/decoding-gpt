    "def char_generate(\n",
    "\tprompt: str,\n",
    "\tchain: Float[np.ndarray, \"d_vocab d_vocab\"],\n",
    "\tvocab: list[str],\n",
    "\tmax_new_chars: int = 100,\n",
    ") -> str:\n",
    "\n",
    "\toutput: list[str] = list(prompt)\n",
    "\n",
    "\t# iterate until we have generated enough characters\n",
    "\tfor i in range(max_new_chars):\n",
    "\t\t# get the last character in the output\n",
    "\t\tc = output[-1]\n",
    "\n",
    "\t\t# find that row in the markov matrix\n",
    "\t\tc_idx = vocab.index(c)\n",
    "\t\tnext_letter_probabilities = chain[c_idx]\n",
    "\n",
    "\t\t# sample the next character from the distribution\n",
    "\t\tc_next = np.random.choice(vocab, p=next_letter_probabilities)\n",
    "\n",
    "\t\t# append it to the output\n",
    "\t\toutput.append(c_next)\n",
    "\n",
    "\treturn \"\".join(output)"
   ]
