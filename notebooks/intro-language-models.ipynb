   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Excercise: Markov Chain as a Neural Network\n",
    "Implement a markov chain as a pytorch module, train it, and compare the weights you get "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "class MarkovChain(torch.nn.Module):\n",
    "\tdef __init__(\n",
    "\t\tself,\n",
    "\t\tvocab_arr: list[str],\n",
    "\t):\n",
    "\t\tsuper().__init__()\n",
    "\t\tself.vocab_arr: list[str] = vocab_arr\n",
    "\t\tself.d_vocab: int = len(vocab_arr)\n",
    "\t\tself.vocab_dict: dict[str, int] = {c: i for i, c in enumerate(vocab_arr)}\n",
    "\n",
    "\t\tself.linear: torch.nn.Module = torch.nn.Linear(\n",
    "\t\t\tself.d_vocab, \n",
    "\t\t\tself.d_vocab,\n",
    "\t\t\tbias=False,\n",
    "\t\t)\n",
    "\n",
    "\tdef forward(\n",
    "\t\tself,\n",
    "\t\tx: Float[torch.Tensor, \" d_vocab\"],\n",
    "\t) -> Float[torch.Tensor, \" d_vocab\"]:\n",
    "\t\toutput: Float[torch.Tensor, \" d_vocab\"] = self.linear(x)\n",
    "\t\treturn output\n",
    "\t\n",
    "\tdef generate(\n",
    "\t\tself,\n",
    "\t\tprompt: list[str],\n",
    "\t\tmax_new_chars: int = 100,\n",
    "\t) -> str:\n",
    "\t\toutput: list[str] = prompt\n",
    "\n",
    "\t\tfor i in range(max_new_chars):\n",
    "\t\t\tc: str = output[-1]\n",
    "\t\t\tc_idx: int = self.vocab_dict[c]\n",
    "\n",
    "\t\t\t# make a a one hot vector for c\n",
    "\t\t\tc_vec: Float[torch.Tensor, \" d_vocab\"] = torch.zeros(self.d_vocab)\n",
    "\t\t\tc_vec[c_idx] = 1\n",
    "\n",
    "\t\t\tnext_letter_probabilities: Float[torch.Tensor, \" d_vocab\"] = self(c_vec)\n",
    "\t\t\t# sample from the probabilities\n",
    "\t\t\tc_next: str = np.random.choice(\n",
    "\t\t\t\tself.vocab_arr, \n",
    "\t\t\t\tp=next_letter_probabilities.detach().numpy(),\n",
    "\t\t\t)\n",
    "\t\t\toutput.append(c_next)\n",
    "\n",
    "\t\treturn \"\".join(output)\n",
    "\n",
    "\n",
    "# left as an exercise to the reader\n",
    "def train_torch_chain(\n",
    "\tdata: list[str],\n",
    "\tvocab: list[str],\n",
    "\tn_epochs: int = 100,\n",
    "\tbatch_size: int = 32,\n",
    ") -> MarkovChain:\n",
    "\t\n",
    "\tchain: MarkovChain = MarkovChain(vocab)\n",
    "\toptimizer: torch.optim.Optimizer = torch.optim.Adam(chain.parameters(), lr=1e-3)\n",
    "\tloss_fn: torch.nn.Module = torch.nn.CrossEntropyLoss()\n",
    "\n",
    "\tfor e in range(n_epochs):\n",
    "\t\tfor i in range(0, len(data) // batch_size): # this skips the last batch if it's not the right size, whatever\n",
    "\t\t\tbatch: list[str] = data[i * batch_size: (i + 1) * batch_size]\n",
    "\n",
    "\t\t\tpredictions: Float[torch.Tensor, \"batch d_vocab\"] = torch.zeros((batch_size, len(vocab)))\n",
    "\t\t\ttargets: Int[torch.Tensor, \" batch\"] = torch.zeros((batch_size,), dtype=torch.long)\n",
    "\n",
    "\n",
    "\treturn chain"
   ]
  },
