    "import torch.nn as nn\n",
    "\n",
    "class ReducedMarkovChain(nn.Module):\n",
    "\tdef __init__(self, d_vocab: int, d_latent: int):\n",
    "\t\tsuper().__init__()\n",
    "\t\tassert d_latent < d_vocab\n",
    "\t\tself.n__d_vocab: int = d_vocab\n",
    "\t\tself.k__d_latent: int = d_latent\n",
    "\n",
    "\t\tself.P__encoder = nn.Linear(d_vocab, d_latent, bias=False)\n",
    "\t\tself.Q__decoder = nn.Linear(d_latent, d_vocab, bias=False)\n",
    "\n",
    "\tdef forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "\t\treturn self.Q__decoder(self.P__encoder(x))\n",
    "\n",
    "\n",
    "def train_reduced_markov_chain(\n",
    "\ttarget_chain: Float[np.ndarray, \"d_vocab d_vocab\"],\n",
    "\td_latent: int,\n",
    "\tn_epochs: int = 100,\n",
    ") -> ReducedMarkovChain:\n",
    "\t\n",
    "\ttarget_chain = torch.tensor(target_chain, dtype=torch.float32)\n",
    "\n",
    "\td_vocab: int = target_chain.shape[0]\n",
    "\n",
    "\tmodel: ReducedMarkovChain = ReducedMarkovChain(d_vocab, d_latent)\n",
    "\n",
    "\toptimizer = torch.optim.Adam(model.parameters(), lr=1e-3)\n",
    "\t\n",
    "\n",
    "\tloss_fn = nn.MSELoss()\n",
    "\n",
    "\tfor e in range(n_epochs):\n",
    "\n",
    "\t\toptimizer.zero_grad()\n",
    "\n",
    "\t\t\n",
    "\t\tx = torch.rand(d_vocab)\n",
    "\n",
    "\t\toutput = model(x)\n",
    "\n",
    "\t\tloss = loss_fn(output, target_chain @ x)\n",
    "\n",
    "\t\tloss.backward()\n",
    "\n",
    "\t\toptimizer.step()\n",
    "\n",
    "\t\tif e % 10 == 0:\n",
    "\t\t\tprint(f\"Epoch {e}: {loss.item()}\")\n",
    "\t\t\n",
    "\n",
    "\treturn model\n",
    "\n",
    "\n",
    "MODEL = train_reduced_markov_chain(\n",
    "\ttarget_chain=CHAIN,\n",
    "\td_latent=100,\n",
    "\tn_epochs=1000,\n",
    ")\n",
    "\n",
    "\t\n",
    "\n"
   ]
